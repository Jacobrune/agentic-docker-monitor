# Required
STACK_DIR=/path/to/your/docker-compose-project

# Optional: path to a markdown file describing your stack architecture and known failure modes.
# The AI agent reads this on every fix attempt.
# CONTEXT_FILE=$STACK_DIR/CONTEXT.md

# Optional: path to a plain-text file with recovery hints appended to every fix prompt.
# RECOVERY_HINTS_FILE=$STACK_DIR/recovery-hints.txt

# Optional: tuning (defaults shown)
# CHECK_INTERVAL=300
# FIX_COOLDOWN=3600
# FIX_MAX_ATTEMPTS=20
